{
  "name": "niuma",
  "version": "0.2.2",
  "type": "module",
  "description": "Niuma (牛马) - 智能生活助手，提供陪伴感和情绪价值的智能精灵",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "niuma": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "pnpm build:agent && pnpm build:web",
    "build:agent": "tsc --project tsconfig.agent.json",
    "build:web": "next build",
    "dev": "next dev",
    "dev:agent": "tsx --watch niuma/index.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "type-check": "tsc --noEmit",
    "type-check:agent": "tsc --project tsconfig.agent.json --noEmit",
    "type-check:web": "tsc --project tsconfig.web.json --noEmit",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "keywords": [
    "ai",
    "assistant",
    "cli",
    "llm",
    "langchain",
    "mcp"
  ],
  "author": "lihaizhong",
  "license": "Apache-2.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^1.1.0",
    "@langchain/core": "^1.1.32",
    "@langchain/openai": "^1.2.13",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@slack/bolt": "^4.0.0",
    "@slack/web-api": "^7.15.0",
    "@sqliteai/sqlite-wasm": "3.50.4-sync.0.8.68-vector.0.9.93-memory.0.7.2",
    "@types/ps-tree": "^1.1.6",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "boxen": "^8.0.1",
    "cac": "^7.0.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "deepmerge": "^4.3.1",
    "dingtalk-sdk": "^0.1.4",
    "discord.js": "^14.18.0",
    "dockerode": "^4.0.10",
    "dotenv": "^17.3.1",
    "fast-clean": "^1.5.3",
    "fast-glob": "^3.3.3",
    "file-type": "^21.3.2",
    "fs-extra": "^11.3.4",
    "imapflow": "^1.0.170",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "langchain": "^1.2.32",
    "nanoid": "^5.1.6",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "node-notifier": "^10.0.1",
    "nodemailer": "^6.10.1",
    "oicq": "^2.3.1",
    "ora": "^9.3.0",
    "ping": "^1.0.0",
    "pino": "^10.3.1",
    "ps-tree": "^1.2.0",
    "re2": "^1.23.3",
    "secure-json-parse": "^4.1.0",
    "tar": "^7.5.11",
    "telegraf": "^4.16.3",
    "which": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^10.0.1",
    "@types/deepmerge": "^2.2.3",
    "@types/dockerode": "^3.3.47",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/which": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.3",
    "eslint-config-next": "^15.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "next": "^15.2.0",
    "postcss": "^8.5.0",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
